generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model tenants {
  tenant_id   String   @id @default(uuid()) @db.Uuid
  name        String
  code        String   @unique
  type        String   @default("company")
  status      String   @default("active")
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  users       users[]
  courses     courses[]
  audit_logs  audit_logs[]
}

model users {
  user_id       String   @id @default(uuid()) @db.Uuid
  tenant_id     String   @db.Uuid
  email         String   @unique
  password_hash String
  first_name    String
  last_name     String
  phone         String?
  avatar_url    String?
  status        String   @default("active")
  last_login    DateTime?
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  tenant             tenants          @relation(fields: [tenant_id], references: [tenant_id])
  user_roles         user_roles[]
  audit_logs         audit_logs[]
  refresh_tokens     refresh_tokens[]
  instructor_courses courses[]        @relation("course_instructor")

  @@index([tenant_id])
  @@index([status])
}

model roles {
  role_id     String   @id @default(uuid()) @db.Uuid
  code        String   @unique
  name        String
  description String?
  created_at  DateTime @default(now())

  user_roles       user_roles[]
  role_permissions role_permissions[]
}

model permissions {
  permission_id String   @id @default(uuid()) @db.Uuid
  code          String   @unique
  name          String
  description   String?

  role_permissions role_permissions[]
}

model user_roles {
  user_role_id String @id @default(uuid()) @db.Uuid
  user_id      String @db.Uuid
  role_id      String @db.Uuid

  user users @relation(fields: [user_id], references: [user_id])
  role roles @relation(fields: [role_id], references: [role_id])

  @@unique([user_id, role_id])
  @@index([user_id])
  @@index([role_id])
}

model role_permissions {
  role_permission_id String @id @default(uuid()) @db.Uuid
  role_id            String @db.Uuid
  permission_id      String @db.Uuid

  role       roles       @relation(fields: [role_id], references: [role_id])
  permission permissions @relation(fields: [permission_id], references: [permission_id])

  @@unique([role_id, permission_id])
}

model refresh_tokens {
  token_id    String    @id @default(uuid()) @db.Uuid
  user_id     String    @db.Uuid
  token_hash  String
  expires_at  DateTime
  revoked_at  DateTime?
  created_at  DateTime  @default(now())

  user users @relation(fields: [user_id], references: [user_id])

  @@index([user_id])
  @@index([expires_at])
}

model courses {
  course_id     String   @id @default(uuid()) @db.Uuid
  tenant_id     String   @db.Uuid
  instructor_id String?  @db.Uuid
  code          String
  name          String
  description   String?
  category      String?
  status        String   @default("draft")
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  tenant     tenants @relation(fields: [tenant_id], references: [tenant_id])
  instructor users?  @relation("course_instructor", fields: [instructor_id], references: [user_id])

  @@unique([tenant_id, code])
  @@index([tenant_id])
  @@index([instructor_id])
  @@index([status])
}

model audit_logs {
  audit_id    String   @id @default(uuid()) @db.Uuid
  tenant_id   String?  @db.Uuid
  user_id     String?  @db.Uuid
  action      String
  entity_type String
  entity_id   String?
  metadata    Json     @default("{}")
  created_at  DateTime @default(now())

  tenant tenants? @relation(fields: [tenant_id], references: [tenant_id])
  user   users?   @relation(fields: [user_id], references: [user_id])

  @@index([tenant_id])
  @@index([user_id])
  @@index([created_at])
  @@index([entity_type])
}
